{
  "mode_id": "self_shuffle",
  "display_name": "Self Shuffle",
  "short_description": "Shuffle a movie's own dialogue back into itself.",
  "source_requirements": {
    "minimum_movies": 1,
    "maximum_movies": 1,
    "requires_transcript": true,
    "requires_speaker_labels": true
  },
  "default_settings": {
    "shuffle_scope": "best_short",
    "speaker_rule": "preserve_speaker",
    "absurdity_level": "medium",
    "target_duration_seconds": 180
  },
  "candidate_generation_strategy": "single_film_dialogue_reassignment",
  "scoring_profile": "balanced",
  "assembly_strategy": "short_self_remix",
  "output_report_fields": [
    "selected_mode",
    "source_files",
    "target_duration",
    "actual_duration",
    "selected_candidate_ids",
    "scoring_breakdown",
    "line_replacement_mapping",
    "warnings",
    "rejected_candidates"
  ],
  "ui_visibility": "default"
}
