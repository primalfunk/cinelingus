{
  "schema_version": "1.0",
  "id": "movie_masher",
  "name": "Movie Masher",
  "description": "Replace destination dialogue with source dialogue.",
  "input_requirements": [
    "destination_video",
    "source_dialogue"
  ],
  "transformation_strategy": "movie_masher",
  "selection_strategy": {
    "source": "source_dialogue.filtered_dialogue_events",
    "destination": "destination_video.filtered_timeline"
  },
  "scheduling": {
    "mode": "config.scheduling_mode",
    "best_fit_lookahead": "config.best_fit_lookahead"
  },
  "render_outputs": {
    "audio": "replacement_dialogue.wav",
    "video": "movie_masher_output.mp4"
  },
  "parameters": {}
}
