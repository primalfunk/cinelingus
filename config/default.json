{
  "destination_video": "source/movie_1.mpg",
  "source_dialogue": "source/movie_2.mp4",
  "cache_dir": "cache",
  "output_dir": "output",
  "temp_dir": "temp",
  "speech_backend": "whisper",
  "transcription_mode": "quality",
  "whisper_model": "medium",
  "whisper_language": "en",
  "quality_modes": {
    "fast_preview": {
      "whisper_model": "tiny"
    },
    "balanced": {
      "whisper_model": "small"
    },
    "quality": {
      "whisper_model": "medium"
    }
  },
  "filter_min_duration": 0.35,
  "filter_max_duration": 12.0,
  "filter_min_confidence": 0.2,
  "filter_min_chars_per_second": 0.5,
  "filter_max_chars_per_second": 28.0,
  "filter_repeated_text_window": 4,
  "silence_noise_db": -35,
  "silence_min_duration": 0.35,
  "min_speech_duration": 0.25,
  "merge_gap": 0.25,
  "max_time_stretch": 0.1,
  "scheduling_mode": "performance_fill",
  "fallback_modes": ["turn_sequence_fill", "whole_line_fill"],
  "unmatched_policy": "suppress_original_dialogue",
  "best_fit_lookahead": 8,
  "render_sample_rate": 48000,
  "render_channels": 2,
  "target_lufs": -18.0,
  "audio_fade_duration": 0.015,
  "original_duck_db": -28.0,
  "dialogue_suppression": "hard_mute",
  "suppression_padding": 0.04,
  "background_reconstruction": "neighboring_non_speech_with_adaptive_crossfades",
  "verify_voice_residue": true,
  "residue_correction_passes": 1,
  "residue_correction_padding": 0.12,
  "editorial_refinement_enabled": true,
  "editorial_max_passes": 2,
  "editorial_acceptance_threshold": 0.72,
  "editorial_min_word_coverage": 0.72,
  "editorial_max_repairs_per_pass": 24,
  "editorial_incremental_render": true,
  "editorial_suppress_unresolved": false,
  "visual_scene_threshold": 0.35,
  "visual_min_shot_duration": 0.5,
  "shot_boundary_mode": "soft",
  "cinematic_filter": "balanced",
  "enable_speaker_awareness": true,
  "speaker_diarization_backend": "pyannote",
  "speaker_diarization_model": "pyannote/speaker-diarization-community-1",
  "speaker_diarization_device": "auto",
  "prefer_high_speaker_confidence": true,
  "prefer_clean_dialogue_timing": true,
  "prefer_funny_or_surprising_matches": true,
  "semantic_mode": "SEMANTIC_DISABLED",
  "semantic_weight": 0.0
}
