# Python bytecode and tooling
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
pytestdebug.log

# Environments and packaging
.venv/
venv/
env/
ENV/
*.egg-info/
.eggs/
build/
dist/
wheelhouse/

# Local secrets and machine-specific configuration
.env
.env.*
!.env.example
*.local.json
config/local*.json
config/*_local.json
secrets/
credentials/
huggingface_token*
hf_token*
access_token*

# IDE and operating-system files
.idea/
.vscode/
*.code-workspace
*.suo
*.user
*.userosscache
*.sln.docstates
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Logs, crash dumps, and profiles
*.log
*.log.*
*.trace
*.prof
*.pstats
*.dmp
crash-*.txt

# Cinelingus runtime artifacts
cache/
output/
temp/
metadata/
dialogue/
clips/
reports/
screenshots/

# Evaluation runs are reproducible working artifacts. Keep compact, curated
# manifests and result summaries as the persistent evidence library; exclude
# schedules, transcriptions, checkpoints, extracted timelines, and other
# per-render intermediates by default.
evaluation/**/*
!evaluation/**/
!evaluation/*.json
evaluation/inventory_cache.json
!evaluation/**/*_screen.json
!evaluation/**/*_proof.json
!evaluation/**/*_audit.json
!evaluation/**/*_repair.json
!evaluation/**/*_preflight.json
!evaluation/**/corpus_manifest.json
!evaluation/**/review_manifest.json
!evaluation/**/answer_key.json
!evaluation/**/calibration_manifest.json
!evaluation/**/calibration_annotations.json
!evaluation/**/calibration_review.md
!evaluation/**/*render_verification*.json
!evaluation/**/*residue_verification.json

# Local source media and extracted audiovisual material
source/*
!source/.gitkeep
*.mp4
*.mkv
*.mov
*.avi
*.mpg
*.mpeg
*.m4v
*.webm
*.wav
*.flac
*.aac
*.m4a
*.mp3

# Models, checkpoints, and large downloaded archives
models/
checkpoints/
*.ckpt
*.pt
*.pth
*.onnx
*.safetensors
*.bin
*.7z
*.zip
*.tar
*.tar.gz
tools/ffmpeg/ffmpeg-*/

# Local scratch and backup files
*.tmp
*.temp
*.bak
*.orig
*.rej
*~
inputs/
