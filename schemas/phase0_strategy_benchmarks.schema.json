{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "phase0_strategy_benchmarks",
  "type": "object",
  "required": [
    "schema_version", "report_version", "tool_version", "creation_timestamp",
    "benchmark_level", "case_count", "passed_case_count", "failed_case_count",
    "all_declared_strategies_executable", "rendered_evidence_claimed", "cases"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "report_version": {"const": "phase0_strategy_contract_benchmarks_v1"},
    "benchmark_level": {"const": "deterministic_pre_render_contract"},
    "case_count": {"type": "integer", "minimum": 1},
    "passed_case_count": {"type": "integer", "minimum": 0},
    "failed_case_count": {"type": "integer", "minimum": 0},
    "all_declared_strategies_executable": {"type": "boolean"},
    "rendered_evidence_claimed": {"const": false},
    "cases": {"type": "array", "minItems": 1, "items": {"type": "object"}}
  }
}
