{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "movie",
  "type": "object",
  "required": ["schema_version", "tool_version", "media_hash", "creation_timestamp", "path", "duration", "streams"],
  "properties": {
    "schema_version": { "type": "string" },
    "tool_version": { "type": "string" },
    "media_hash": { "type": "string" },
    "creation_timestamp": { "type": "string" },
    "path": { "type": "string" },
    "duration": { "type": "number" },
    "resolution": { "type": ["string", "null"] },
    "frame_rate": { "type": ["number", "null"] },
    "sample_rate": { "type": ["integer", "null"] },
    "channels": { "type": ["integer", "null"] },
    "codec": { "type": ["string", "null"] },
    "streams": { "type": "array" }
  }
}
