{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "filter_contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "contract_version", "filter_id", "filter_name", "family_id", "filter_version",
    "status", "implementation_class", "creative_proposition", "relationship_domains", "specimen_inputs",
    "required_analysis", "capabilities", "blockers"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "contract_version": {"type": "string", "pattern": "[0-9]+\\.[0-9]+\\.[0-9]+"},
    "filter_id": {"type": "string", "pattern": "[a-z_]+\\.[a-z_]+"},
    "filter_name": {"type": "string", "minLength": 1},
    "family_id": {"type": "string", "enum": ["translation", "infection", "identity", "memory", "emotion", "time", "experimental", "multiworld"]},
    "filter_version": {"type": "string", "pattern": "[0-9]+\\.[0-9]+\\.[0-9]+"},
    "status": {"type": "string", "enum": ["accepted", "blocked", "deferred"]},
    "implementation_class": {"type": "string", "enum": ["A", "B", "C", "D", "E", "F"]},
    "creative_proposition": {"type": "string", "minLength": 12},
    "relationship_domains": {
      "type": "object", "additionalProperties": false, "required": ["reads", "changes", "preserves"],
      "properties": {
        "reads": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["dialogue", "performance", "identity", "time", "scene_order", "emotion", "music", "soundscape", "shot_selection", "narration", "genre"]}},
        "changes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["dialogue", "performance", "identity", "time", "scene_order", "emotion", "music", "soundscape", "shot_selection", "narration", "genre"]}},
        "preserves": {"type": "object"}
      }
    },
    "specimen_inputs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "required_analysis": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "candidate_generation": {"type": "string", "minLength": 12},
    "selection_rules": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "transformation_behavior": {"type": "string", "minLength": 12},
    "progression": {"type": "string", "minLength": 8},
    "state_variables": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "fields": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "controlled_uncertainty": {"type": "string", "minLength": 8},
    "hard_invariants": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["id", "statement", "validator"],
        "properties": {
          "id": {"type": "string", "pattern": "[a-z0-9_]+"},
          "statement": {"type": "string", "minLength": 8},
          "validator": {"type": "string"}
        }
      }
    },
    "validation": {
      "type": "object", "additionalProperties": false, "required": ["strategy", "required_metrics"],
      "properties": {
        "strategy": {"type": "string", "minLength": 8},
        "required_metrics": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "failure_behavior": {"type": "string", "minLength": 8},
    "preview_strategy": {"type": "string", "minLength": 8},
    "renderer_requirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "procedure_behavior": {
      "type": "object", "additionalProperties": false, "required": ["support_status", "receives_transformed_specimen", "commitment"],
      "properties": {
        "support_status": {"type": "string", "enum": ["conceptual", "single_step_validated", "multi_step_validated"]},
        "receives_transformed_specimen": {"type": "boolean"},
        "commitment": {"type": "string", "minLength": 12}
      }
    },
    "capabilities": {
      "type": "object", "additionalProperties": false,
      "required": ["implemented", "implementation_key", "execution_mode", "sparse_schedule", "requires_speaker_identity", "supports_preview", "supports_best_short", "supports_full_length", "requires_output_acceptance"],
      "properties": {
        "implemented": {"type": "boolean"},
        "implementation_key": {"type": ["string", "null"]},
        "execution_mode": {"type": "string", "enum": ["transformation", "scheduling_strategy", "unavailable"]},
        "sparse_schedule": {"type": "boolean"},
        "requires_speaker_identity": {"type": "boolean"},
        "supports_preview": {"type": "boolean"},
        "supports_best_short": {"type": "boolean"},
        "supports_full_length": {"type": "boolean"},
        "requires_output_acceptance": {"type": "boolean"}
      }
    },
    "blockers": {"type": "array", "items": {"type": "string", "minLength": 8}},
    "multiworld_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cinematic_law", "minimum_films", "maximum_films", "anchor_behavior", "affected_elements", "quality_requirements", "deterministic_seed_support", "interface"],
      "properties": {
        "cinematic_law": {"type": "string", "minLength": 3},
        "minimum_films": {"type": "integer", "minimum": 2},
        "maximum_films": {"type": ["integer", "null"], "minimum": 2},
        "anchor_behavior": {"type": "string", "enum": ["anchor_timeline", "shared_timeline", "law_defined_timeline"]},
        "affected_elements": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "enum": ["dialogue", "performance", "identity", "time", "scene_order", "emotion", "music", "soundscape", "shot_selection", "narration", "genre"]}},
        "quality_requirements": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
        "deterministic_seed_support": {"type": "boolean"},
        "interface": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inputs", "outputs", "affected_artifacts", "intermediate_products"],
          "properties": {
            "inputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "outputs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "affected_artifacts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
            "intermediate_products": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"family_id": {"const": "multiworld"}}},
      "then": {"required": ["multiworld_contract"]}
    },
    {
      "if": {"properties": {"status": {"const": "accepted"}}},
      "then": {"required": ["candidate_generation", "selection_rules", "transformation_behavior", "progression", "state_variables", "fields", "controlled_uncertainty", "hard_invariants", "validation", "failure_behavior", "preview_strategy", "renderer_requirements", "procedure_behavior"]}
    }
  ]
}
