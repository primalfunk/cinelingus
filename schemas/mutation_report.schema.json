    "source_media_hash": { "type": "string" },
    "mutation_filter": { "type": "object" },
    "parameters": { "type": "object" },
    "counts": { "type": "object" },
    "outputs": { "type": "object" },
    "artifacts": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "review_summary": { "type": "object" }
