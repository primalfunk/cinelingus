    "source_media_hash": { "type": "string" },
    "source_path": { "type": "string" },
    "parameters": { "type": "object" },
    "selected_objects": { "type": "array" },
    "operation_list": { "type": "array" },
    "placement_plan": { "type": "array" },
    "render_strategy": { "type": "object" },
    "warnings": { "type": "array", "items": { "type": "string" } },
