{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cinelingus Filter Combination Compatibility Matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "compiler_version", "creation_timestamp", "matrix_signature", "filter_count", "ordered_pair_count", "status_counts", "executable_pair_ids", "decisions"],
  "properties": {
    "schema_version": {"type": "string", "const": "1.0"},
    "compiler_version": {"type": "string", "minLength": 1},
    "creation_timestamp": {"type": "string", "minLength": 1},
    "matrix_signature": {"type": "string", "minLength": 64},
    "filter_count": {"type": "integer", "minimum": 1},
    "ordered_pair_count": {"type": "integer", "minimum": 1},
    "status_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["CERTIFIED", "COMPATIBLE_UNPROVEN", "REQUIRES_REANALYSIS", "INCOMPATIBLE", "UNAVAILABLE"],
      "properties": {
        "CERTIFIED": {"type": "integer", "minimum": 0},
        "COMPATIBLE_UNPROVEN": {"type": "integer", "minimum": 0},
        "REQUIRES_REANALYSIS": {"type": "integer", "minimum": 0},
        "INCOMPATIBLE": {"type": "integer", "minimum": 0},
        "UNAVAILABLE": {"type": "integer", "minimum": 0}
      }
    },
    "executable_pair_ids": {"type": "array", "items": {"type": "string", "minLength": 3}, "uniqueItems": true},
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pair_id", "predecessor_filter_id", "successor_filter_id", "status", "executable", "checks", "shared_relationship_domains", "reasons", "evidence", "compiler_version"],
        "properties": {
          "pair_id": {"type": "string", "minLength": 3},
          "predecessor_filter_id": {"type": "string", "minLength": 1},
          "successor_filter_id": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["CERTIFIED", "COMPATIBLE_UNPROVEN", "REQUIRES_REANALYSIS", "INCOMPATIBLE", "UNAVAILABLE"]},
          "executable": {"type": "boolean"},
          "checks": {"type": "object", "minProperties": 1},
          "shared_relationship_domains": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "reasons": {"type": "array", "items": {"type": "string"}},
          "evidence": {"type": "object"},
          "compiler_version": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
