{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "phase0_strategy_coverage",
  "type": "object",
  "required": [
    "schema_version", "report_version", "tool_version", "creation_timestamp",
    "contract_report", "calibration_reports", "declared_strategy_count",
    "contract_executable_count", "runtime_attempted_strategy_count",
    "rendered_strategy_count", "surviving_strategy_count", "evidence_satisfied_strategy_count",
    "missing_rendered_strategies", "missing_strategy_evidence",
    "phase0_rendered_strategy_gate_passed", "strategies"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "report_version": {"const": "phase0_rendered_strategy_coverage_v1"},
    "calibration_reports": {"type": "array", "items": {"type": "string"}},
    "declared_strategy_count": {"type": "integer", "minimum": 1},
    "contract_executable_count": {"type": "integer", "minimum": 0},
    "runtime_attempted_strategy_count": {"type": "integer", "minimum": 0},
    "rendered_strategy_count": {"type": "integer", "minimum": 0},
    "surviving_strategy_count": {"type": "integer", "minimum": 0},
    "evidence_satisfied_strategy_count": {"type": "integer", "minimum": 0},
    "missing_rendered_strategies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_strategy_evidence": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "phase0_rendered_strategy_gate_passed": {"type": "boolean"},
    "strategies": {"type": "array", "minItems": 1, "items": {"type": "object"}}
  }
}
