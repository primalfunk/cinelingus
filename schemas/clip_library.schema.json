{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "clip_library",
  "type": "object",
  "required": [
    "schema_version",
    "tool_version",
    "media_hash",
    "creation_timestamp",
    "clips"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "media_hash": {
      "type": "string"
    },
    "creation_timestamp": {
      "type": "string"
    },
    "clips": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "path",
          "movie_timestamp",
          "duration",
          "transcript",
          "speech_rate",
          "average_loudness"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "movie_timestamp": {
            "type": "number"
          },
          "duration": {
            "type": "number"
          },
          "transcript": {
            "type": "string"
          },
          "speaker": {
            "type": [
              "string",
              "null"
            ]
          },
          "speech_rate": {
            "type": "number"
          },
          "average_loudness": {
            "type": [
              "number",
              "null"
            ]
          },
          "confidence": {
            "type": [
              "number",
              "null"
            ]
          },
          "usable": {
            "type": "boolean"
          },
          "reject_reason": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    }
  }
}
