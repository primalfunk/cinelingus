          "mapping_index",
          "window_id",
          "clip_id",
          "review_label",
          "enabled"
        ],
        "properties": {
          "mapping_index": {
            "type": "integer"
          },
          "window_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "clip_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "review_label": {
            "type": "string"
          },
          "review_note": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "destination_timestamp": {
            "type": [
              "number",
              "null"
            ]
          },
          "score": {
            "type": [
              "number",
              "null"
            ]
          },
          "visual_fit_score": {
            "type": [
              "number",
              "null"
            ]
          },
          "mapping_crosses_shot_boundary": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
