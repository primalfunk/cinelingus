{
  "type": "object",
  "required": [
    "schema_version",
    "tool_version",
    "media_hash",
    "creation_timestamp",
    "total_mappings",
    "reviewed_mappings",
    "label_counts",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "tool_version": {
      "type": "string"
    },
    "media_hash": {
      "type": "string"
    },
    "creation_timestamp": {
      "type": "string"
    },
    "schedule_path": {
      "type": "string"
    },
    "total_mappings": {
      "type": "integer"
    },
    "reviewed_mappings": {
      "type": "integer"
    },
    "label_counts": {
      "type": "object"
