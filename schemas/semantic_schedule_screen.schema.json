{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "semantic_schedule_screen",
  "type": "object",
  "required": [
    "schema_version", "experiment_version", "creation_timestamp", "experiment_signature",
    "source_hash", "destination_hash", "scheduling_mode", "weight_grid",
    "semantic_model_identity", "invariants", "variants", "render_selection",
    "render_selection_state", "claim_scope"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "experiment_version": {"const": "semantic_schedule_screen_v1"},
    "weight_grid": {"type": "array", "items": {"type": "number", "minimum": 0, "maximum": 1}},
    "variants": {"type": "array", "items": {"type": "object", "required": ["variant_id", "mode", "weight", "mapping_count", "placements_changed", "conflict_count"]}},
    "render_selection": {"type": "array", "items": {"type": "string"}},
    "render_selection_state": {"enum": ["ASSISTED_CANDIDATE_SELECTED", "NO_CONFLICT_FREE_CHANGED_ASSISTED_CANDIDATE"]}
  }
}
